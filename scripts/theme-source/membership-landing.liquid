<section class="membership-landing" id="shopify-section-{{ section.id }}">
  <div class="membership-landing__hero">
    <img class="membership-landing__hero-image" src="{{ 'membership-landing-hero.jpg' | asset_url }}" alt="{{ section.settings.hero_image_alt | escape }}" width="1600" height="1800" loading="eager">
    <div class="membership-landing__hero-copy">
      <p class="section-eyebrow">{{ section.settings.hero_eyebrow | escape }}</p>
      <h1 class="section-heading section-heading--light">{{ section.settings.hero_heading | escape }}</h1>
      <p class="membership-landing__hero-body">{{ section.settings.hero_body | escape }}</p>
      <div class="membership-landing__hero-actions">
        <a class="button-outline button-outline--accent" href="{{ section.settings.hero_primary_url }}">{{ section.settings.hero_primary_label | escape }}</a>
        <a class="membership-landing__secondary-link" href="{{ section.settings.hero_secondary_url }}">{{ section.settings.hero_secondary_label | escape }}</a>
      </div>
    </div>
  </div>
  <div class="membership-landing__trust">
    {% assign perk_blocks = section.blocks | where: 'type', 'perk' %}
    {% for block in perk_blocks %}
      <div class="membership-landing__trust-item" {{ block.shopify_attributes }}>
        <span class="membership-landing__trust-label">{{ block.settings.label | escape }}</span>
        <span class="membership-landing__trust-sub">{{ block.settings.sub_label | escape }}</span>
      </div>
    {% endfor %}
  </div>
  <div class="membership-landing__section" id="how-it-works">
    <div class="membership-landing__section-copy">
      <p class="section-eyebrow">The Process</p>
      <h2 class="section-heading">How It Works</h2>
    </div>
    {% assign step_blocks = section.blocks | where: 'type', 'step' %}
    {% for block in step_blocks %}
      {% capture asset_name %}membership-landing-step-{{ forloop.index }}.jpg{% endcapture %}
      <div class="membership-landing__step" {{ block.shopify_attributes }}>
        <img class="membership-landing__step-image" src="{{ asset_name | asset_url }}" alt="{{ block.settings.image_alt | escape }}" width="1080" height="900" loading="lazy">
        <div class="membership-landing__step-copy">
          <span class="membership-landing__step-number">Step {{ block.settings.step_number | escape }}</span>
          <h3 class="membership-landing__step-title">{{ block.settings.title | escape }}</h3>
          <p class="membership-landing__step-body">{{ block.settings.body | escape }}</p>
          <p class="membership-landing__step-detail">{{ block.settings.detail | escape }}</p>
        </div>
      </div>
    {% endfor %}
  </div>
  <div class="membership-landing__benefits">
    {% assign benefit_blocks = section.blocks | where: 'type', 'benefit' %}
    {% for block in benefit_blocks %}
      <article class="membership-landing__benefit" {{ block.shopify_attributes }}>
        <h3>{{ block.settings.title | escape }}</h3>
        <p>{{ block.settings.body | escape }}</p>
      </article>
    {% endfor %}
  </div>
  <div class="membership-landing__tiers">
    {% assign tier_blocks = section.blocks | where: 'type', 'tier' %}
    {% for block in tier_blocks %}
      <article class="membership-landing__tier" {{ block.shopify_attributes }}>
        {% if block.settings.badge != blank %}<span class="membership-landing__tier-badge">{{ block.settings.badge | escape }}</span>{% endif %}
        <p class="membership-landing__tier-name">{{ block.settings.name | escape }}</p>
        <h3 class="membership-landing__tier-price">{{ block.settings.price | escape }}</h3>
        <p class="membership-landing__tier-meta">{{ block.settings.pieces | escape }} · {{ block.settings.value | escape }}</p>
        <p class="membership-landing__tier-tagline">{{ block.settings.tagline | escape }}</p>
        <p class="membership-landing__tier-summary">{{ block.settings.summary | escape }}</p>
        <a class="button-outline" href="{{ block.settings.cta_url }}">{{ block.settings.cta_label | escape }}</a>
      </article>
    {% endfor %}
  </div>
  <div class="membership-landing__comparison">
    {% assign comparison_blocks = section.blocks | where: 'type', 'comparison' %}
    {% for block in comparison_blocks %}
      <div class="membership-landing__comparison-row" {{ block.shopify_attributes }}>
        <span>{{ block.settings.feature | escape }}</span>
        <span>{{ block.settings.member | escape }}</span>
        <span>{{ block.settings.non_member | escape }}</span>
      </div>
    {% endfor %}
  </div>
  <div class="membership-landing__testimonials">
    {% assign testimonial_blocks = section.blocks | where: 'type', 'testimonial' %}
    {% for block in testimonial_blocks %}
      {% capture asset_name %}membership-landing-testimonial-{{ forloop.index }}.jpg{% endcapture %}
      <article class="membership-landing__testimonial" {{ block.shopify_attributes }}>
        <img class="membership-landing__testimonial-image" src="{{ asset_name | asset_url }}" alt="{{ block.settings.image_alt | escape }}" width="120" height="120" loading="lazy">
        <p class="membership-landing__testimonial-quote">“{{ block.settings.quote | escape }}”</p>
        <p class="membership-landing__testimonial-meta">{{ block.settings.name | escape }} · {{ block.settings.location | escape }} · {{ block.settings.tier | escape }}</p>
      </article>
    {% endfor %}
  </div>
  <div class="membership-landing__faq">
    {% assign faq_blocks = section.blocks | where: 'type', 'faq' %}
    {% for block in faq_blocks %}
      <details class="membership-landing__faq-item" {{ block.shopify_attributes }}>
        <summary>{{ block.settings.question | escape }}</summary>
        <p>{{ block.settings.answer | escape }}</p>
      </details>
    {% endfor %}
  </div>
  <div class="membership-landing__cta">
    <img class="membership-landing__cta-image" src="{{ 'membership-landing-cta.jpg' | asset_url }}" alt="{{ section.settings.cta_image_alt | escape }}" width="1600" height="1000" loading="lazy">
    <div class="membership-landing__cta-copy">
      <p class="section-eyebrow">{{ section.settings.cta_eyebrow | escape }}</p>
      <h2 class="section-heading section-heading--light">{{ section.settings.cta_heading | escape }}</h2>
      <p>{{ section.settings.cta_body | escape }}</p>
      <div class="membership-landing__hero-actions">
        <a class="button-outline button-outline--accent" href="{{ section.settings.cta_primary_url }}">{{ section.settings.cta_primary_label | escape }}</a>
        <a class="membership-landing__secondary-link" href="{{ section.settings.cta_secondary_url }}">{{ section.settings.cta_secondary_label | escape }}</a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Membership landing",
  "settings": [
    { "type": "text", "id": "hero_eyebrow", "label": "Hero eyebrow" },
    { "type": "textarea", "id": "hero_heading", "label": "Hero heading" },
    { "type": "textarea", "id": "hero_body", "label": "Hero body" },
    { "type": "text", "id": "hero_primary_label", "label": "Hero primary label" },
    { "type": "url", "id": "hero_primary_url", "label": "Hero primary URL" },
    { "type": "text", "id": "hero_secondary_label", "label": "Hero secondary label" },
    { "type": "url", "id": "hero_secondary_url", "label": "Hero secondary URL" },
    { "type": "text", "id": "hero_image_alt", "label": "Hero image alt" },
    { "type": "text", "id": "cta_eyebrow", "label": "CTA eyebrow" },
    { "type": "textarea", "id": "cta_heading", "label": "CTA heading" },
    { "type": "textarea", "id": "cta_body", "label": "CTA body" },
    { "type": "text", "id": "cta_primary_label", "label": "CTA primary label" },
    { "type": "url", "id": "cta_primary_url", "label": "CTA primary URL" },
    { "type": "text", "id": "cta_secondary_label", "label": "CTA secondary label" },
    { "type": "url", "id": "cta_secondary_url", "label": "CTA secondary URL" },
    { "type": "text", "id": "cta_image_alt", "label": "CTA image alt" }
  ],
  "blocks": [
    { "type": "perk", "name": "Trust perk", "settings": [{ "type": "text", "id": "label", "label": "Label" }, { "type": "text", "id": "sub_label", "label": "Sub label" }] },
    { "type": "step", "name": "Step", "settings": [{ "type": "text", "id": "step_number", "label": "Step number" }, { "type": "text", "id": "title", "label": "Title" }, { "type": "textarea", "id": "body", "label": "Body" }, { "type": "textarea", "id": "detail", "label": "Detail" }, { "type": "text", "id": "image_alt", "label": "Image alt" }] },
    { "type": "benefit", "name": "Benefit", "settings": [{ "type": "text", "id": "title", "label": "Title" }, { "type": "textarea", "id": "body", "label": "Body" }] },
    { "type": "tier", "name": "Tier", "settings": [{ "type": "text", "id": "name", "label": "Name" }, { "type": "text", "id": "price", "label": "Price" }, { "type": "text", "id": "value", "label": "Value" }, { "type": "text", "id": "pieces", "label": "Pieces" }, { "type": "text", "id": "tagline", "label": "Tagline" }, { "type": "textarea", "id": "summary", "label": "Summary" }, { "type": "text", "id": "badge", "label": "Badge" }, { "type": "text", "id": "cta_label", "label": "CTA label" }, { "type": "url", "id": "cta_url", "label": "CTA URL" }] },
    { "type": "comparison", "name": "Comparison row", "settings": [{ "type": "text", "id": "feature", "label": "Feature" }, { "type": "textarea", "id": "member", "label": "Member text" }, { "type": "textarea", "id": "non_member", "label": "Non-member text" }] },
    { "type": "testimonial", "name": "Testimonial", "settings": [{ "type": "text", "id": "name", "label": "Name" }, { "type": "text", "id": "location", "label": "Location" }, { "type": "text", "id": "tier", "label": "Tier" }, { "type": "textarea", "id": "quote", "label": "Quote" }, { "type": "text", "id": "image_alt", "label": "Image alt" }] },
    { "type": "faq", "name": "FAQ", "settings": [{ "type": "text", "id": "question", "label": "Question" }, { "type": "textarea", "id": "answer", "label": "Answer" }] }
  ],
  "presets": [{ "name": "Membership landing" }]
}
{% endschema %}
