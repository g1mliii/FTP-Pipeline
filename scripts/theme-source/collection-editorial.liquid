<section class="editorial-collection" id="shopify-section-{{ section.id }}">
  <div class="editorial-collection__hero">
    <p class="section-eyebrow">{{ section.settings.eyebrow | escape }}</p>
    <h1 class="section-heading">{{ section.settings.heading | escape }}</h1>
    <p class="editorial-collection__intro">{{ section.settings.intro | escape }}</p>
  </div>
  <div class="editorial-collection__filters">
    {% assign filter_labels = section.settings.filter_labels | split: '|' %}
    {% for label in filter_labels %}
      <span class="editorial-collection__filter">{{ label | strip | escape }}</span>
    {% endfor %}
  </div>
  <div class="editorial-collection__grid">
    {% assign product_blocks = section.blocks | where: 'type', 'product' %}
    {% assign editorial_blocks = section.blocks | where: 'type', 'editorial' %}
    {% for block in product_blocks %}
      {% capture asset_name %}collection-editorial-product-{{ forloop.index }}.jpg{% endcapture %}
      <a class="editorial-collection__card" href="{{ block.settings.link_url | default: '/products/vue-chain-necklace' }}" {{ block.shopify_attributes }}>
        {% if block.settings.image != blank %}
          {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', class: 'editorial-collection__image', alt: block.settings.image.alt | default: block.settings.image_alt }}
        {% else %}
          <img class="editorial-collection__image" src="{{ asset_name | asset_url }}" alt="{{ block.settings.image_alt | escape }}" width="1080" height="1320" loading="lazy">
        {% endif %}
        {% if block.settings.tag != blank %}<span class="editorial-collection__badge">{{ block.settings.tag | escape }}</span>{% endif %}
        <div class="editorial-collection__card-copy">
          <h3 class="editorial-collection__title">{{ block.settings.title | escape }}</h3>
          <p class="editorial-collection__price">{{ block.settings.price | escape }}</p>
        </div>
      </a>
    {% endfor %}
    {% for block in editorial_blocks %}
      <div class="editorial-collection__card editorial-collection__card--feature" {{ block.shopify_attributes }}>
        {% if block.settings.image != blank %}
          {{ block.settings.image | image_url: width: 1400 | image_tag: loading: 'lazy', class: 'editorial-collection__image', alt: block.settings.image.alt | default: block.settings.image_alt }}
        {% else %}
          <img class="editorial-collection__image" src="{{ 'collection-editorial-feature.jpg' | asset_url }}" alt="{{ block.settings.image_alt | escape }}" width="1080" height="1320" loading="lazy">
        {% endif %}
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Collection editorial",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "textarea", "id": "intro", "label": "Intro" },
    { "type": "text", "id": "filter_labels", "label": "Filter labels" }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product card",
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "text", "id": "price", "label": "Price" },
        { "type": "text", "id": "tag", "label": "Tag" },
        { "type": "url", "id": "link_url", "label": "Link URL" },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "image_alt", "label": "Image alt" }
      ]
    },
    {
      "type": "editorial",
      "name": "Editorial image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "image_alt", "label": "Image alt" }
      ]
    }
  ],
  "presets": [{ "name": "Collection editorial" }]
}
{% endschema %}
